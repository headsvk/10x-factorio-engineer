{
  "name": "10x-factorio-engineer-dev",
  "private": true,
  "scripts": {
    "build": "esbuild dev/dashboard.jsx --bundle=false --minify --target=es2020 --outfile=10x-factorio-engineer/assets/dashboard.min.js",
    "postbuild": "node -e \"const f='10x-factorio-engineer/assets/dashboard.min.js',s=require('fs').readFileSync(f,'utf8').replace(/export default function \\w+/,'function FactoryDashboard');require('fs').writeFileSync(f,s);\""
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
